# Optional absolute data-hub BFF origin for browser runtime.
# Prefer leaving this empty in Vite development so requests use the same-origin /api proxy.
VITE_DATAHUB_API_BASE_URL=

# Vite /api proxy target. The production-like platform login page currently uses:
# - POST /api/auth/login for platform users
# - POST /api/admin/login for system administrators
VITE_DATAHUB_PROXY_TARGET=http://119.27.182.204

# Optional local data-hub BFF port. Used only when VITE_DATAHUB_PROXY_TARGET is not set.
# VITE_DATAHUB_BFF_PORT=8090
